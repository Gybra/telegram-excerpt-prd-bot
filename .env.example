# ─── Telegram ─────────────────────────────────────────────────────────
# Admin bot token (the one you use to manage the other bots via commands)
TELEGRAM_ADMIN_BOT_TOKEN=123456:ABC-DEF_your-admin-bot-token-here

# Admin's private chat ID. Only this chat_id can issue commands and
# receives the generated PRDs. To find it: write to your admin bot and
# visit https://api.telegram.org/bot<TOKEN>/getUpdates
FORWARD_CHAT_ID=123456789

# ─── OpenRouter (LLM) ─────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_MODEL=qwen/qwen3.6-plus:free

# ─── Google Cloud Firestore ───────────────────────────────────────────
# Path to the service account JSON file (mounted as volume in Docker).
# The service account needs the "Cloud Datastore User" role.
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/firebase.json
FIRESTORE_PROJECT_ID=your-gcp-project-id

# ─── Runtime mode ─────────────────────────────────────────────────────
# polling → local use (docker-compose). The bot uses long polling and an
#           internal asyncio loop triggers the flush every 30 seconds.
# webhook → production (Cloud Run). The app exposes HTTP endpoints,
#           Telegram pushes updates via webhook, Cloud Scheduler triggers
#           /tasks/process every minute.
MODE=polling

# Public HTTPS URL where Cloud Run is deployed. Required only if
# MODE=webhook. Example: https://telegram-excerpt-xxx-ew.a.run.app
BASE_URL=

# ─── Processing ───────────────────────────────────────────────────────
# Seconds of silence in a group before the batch flush triggers.
BATCH_SILENCE_SECONDS=180

# Default maximum messages per batch (override per-bot via /set_n).
DEFAULT_N=50

# ─── Internal endpoint auth (only MODE=webhook) ───────────────────────
# Bearer token sent by Cloud Scheduler in the Authorization header to
# call /tasks/process and /admin/setup. Generate with: openssl rand -hex 32
SCHEDULER_AUTH_TOKEN=change-me-to-a-long-random-string

# ─── Chat responder (optional feature, off by default) ────────────────
# If true, every child bot also replies to each group message via LLM.
# WARNING: this burns through LLM tokens fast in busy groups. The default
# system prompt tells the model to answer SKIP when it has nothing to
# add, so the bot stays silent unless it can contribute.
CHAT_RESPONDER_ENABLED=false

# Custom system prompt for the responder. Keep the SKIP instruction to
# avoid spam. Quoted strings with newlines/commas are supported by
# pydantic-settings.
# CHAT_RESPONDER_SYSTEM_PROMPT="Sei un assistente amichevole..."

# Optional override of the responder model (defaults to OPENROUTER_MODEL).
# CHAT_RESPONDER_MODEL=anthropic/claude-3.5-haiku

# Max tokens for each responder reply (16-2000).
CHAT_RESPONDER_MAX_TOKENS=400
